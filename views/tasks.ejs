<!DOCTYPE html>
<html>

<head>
    <title>Tasks</title>
</head>

<body>

    <h1>All Tasks</h1>

    <a href="/tasks/new">Create New Task</a>

    <% if (message.length> 0) { %>

        <p style="color:green;">
            <%= message %>
        </p>

        <% } %>

            <table border="1">

                <tr>
                    <th>ID</th>
                    <th>Title</th>
                    <th>Completed</th>
                    <th>Actions</th>
                </tr>

                <% tasks.forEach(task=> { %>

                    <tr>

                        <td>
                            <%= task.id %>
                        </td>

                        <td>
                            <%= task.title %>
                        </td>

                        <td>
                            <%= task.completed %>
                        </td>

                        <td>

                            <a href="/tasks/<%= task.id %>">View</a>

                            <a href="/tasks/edit/<%= task.id %>">Edit</a>

                            <a href="/tasks/delete/<%= task.id %>">Delete</a>

                        </td>

                    </tr>

                    <% }) %>

            </table>

</body>

</html>